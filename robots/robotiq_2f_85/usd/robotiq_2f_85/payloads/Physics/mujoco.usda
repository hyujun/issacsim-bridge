Generated from Composed Stage of root layer /workspace/robots/robotiq_2f_85/usd/robotiq_2f_85/payloads/base.usd
"""
    kilogramsPerUnit = 1
    metersPerUnit = 1
    subLayers = [
        @./physics.usda@
    ]
    upAxis = "Z"
)

over "robotiq_gripper"
{
    over "Physics"
    {
        def MjcActuator "robotiq_85_left_knuckle_joint_actuator"
        {
            uniform double mjc:forceRange:max = 50
            uniform double mjc:forceRange:min = -50
            custom rel mjc:target
            prepend rel mjc:target = </robotiq_gripper/Physics/robotiq_85_left_knuckle_joint>
        }

        def MjcActuator "robotiq_85_right_knuckle_joint_actuator"
        {
            uniform double mjc:forceRange:max = 50
            uniform double mjc:forceRange:min = -50
            custom rel mjc:target
            prepend rel mjc:target = </robotiq_gripper/Physics/robotiq_85_right_knuckle_joint>
        }

        def MjcActuator "robotiq_85_left_inner_knuckle_joint_actuator"
        {
            uniform double mjc:forceRange:max = inf
            uniform double mjc:forceRange:min = -inf
            custom rel mjc:target
            prepend rel mjc:target = </robotiq_gripper/Physics/robotiq_85_left_inner_knuckle_joint>
        }

        def MjcActuator "robotiq_85_right_inner_knuckle_joint_actuator"
        {
            uniform double mjc:forceRange:max = inf
            uniform double mjc:forceRange:min = -inf
            custom rel mjc:target
            prepend rel mjc:target = </robotiq_gripper/Physics/robotiq_85_right_inner_knuckle_joint>
        }

        def MjcActuator "robotiq_85_left_finger_tip_joint_actuator"
        {
            uniform double mjc:forceRange:max = inf
            uniform double mjc:forceRange:min = -inf
            custom rel mjc:target
            prepend rel mjc:target = </robotiq_gripper/Physics/robotiq_85_left_finger_tip_joint>
        }

        def MjcActuator "robotiq_85_right_finger_tip_joint_actuator"
        {
            uniform double mjc:forceRange:max = inf
            uniform double mjc:forceRange:min = -inf
            custom rel mjc:target
            prepend rel mjc:target = </robotiq_gripper/Physics/robotiq_85_right_finger_tip_joint>
        }

        over "robotiq_85_base_joint"
        {
        }

        over "robotiq_85_left_knuckle_joint" (
            delete apiSchemas = ["PhysicsDriveAPI:angular", "PhysicsJointStateAPI:angular"]
        )
        {
        }

        over "robotiq_85_right_knuckle_joint" (
